# Godot generated files
game/.godot/
mobile/game/.godot/

# Bundled engine (re-download from godotengine.org if needed). Ignore the
# CONTENTS of tools/, not the directory itself — git will not descend into
# an excluded dir, so `tools/` + `!tools/art/` silently keeps the art
# pipeline untracked. tools/art IS source: the sprite matte/generation
# scripts live there.
tools/*
!tools/art/
!tools/content/
!tools/*.py
!tools/INDEX.md
tools/art/__pycache__/
tools/content/__pycache__/
tools/__pycache__/

# Local art backups (replaced originals + generation candidates; never commit)
backup/

# Exports
build/
executables/
mobile/builds/
*.exe
*.apk
*.aab
*.ipa

# Claude session scratch (never commit)
claude_test_run.bat
claude_test.log
claude_stage.bat
claude_stage.log
.claude/
.claude_tmp_copy/

# Bench / test outputs (regenerated; never commit)
dps_*.txt
test_full_run.log

# Companion webnovel (kept local; not part of the game project)
webnovel/
