## Merge + resolution check: every curio grantable, every icon/sprite
## resolves to installed art. Wall-clock-free.
static func selftest(_game: Node2D) -> String:
	for id in QUEST_ITEMS:
		if not Story.ALL_QUEST_ITEMS.has(id):
			return "rv_na_gallery: quest item %s not merged" % id
		var item := Items.make_quest_item(String(id))
		if item.is_empty() or item.get("kind", "") != "quest":
			return "rv_na_gallery: make_quest_item(%s) did not build a bag rider" % id
		if Art.tex(String(QUEST_ITEMS[id]["icon"])) == null:
			return "rv_na_gallery: icon %s missing" % QUEST_ITEMS[id]["icon"]
	for id in RELICS:
		if not Story.ALL_RELICS.has(id):
			return "rv_na_gallery: relic %s not merged" % id
		if Art.tex(String(RELICS[id]["sprite"])) == null:
			return "rv_na_gallery: relic sprite %s missing" % RELICS[id]["sprite"]
	# critters also ship a 2-frame _anim strip — verify those resolve too
	for id in RELICS:
		if String(RELICS[id].get("group", "")) == "critters":
			if Art.tex(String(RELICS[id]["sprite"]) + "_anim") == null:
				return "rv_na_gallery: critter strip %s_anim missing" % RELICS[id]["sprite"]
	return ""
