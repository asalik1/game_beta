# One short line per named resident (the ch2-hub CONVOS pattern). Merged into
# Story.ALL_CONVOS via the CONTENT_MODULES registration.
const CONVOS := {
	"cap_citizen": {"start": "a", "nodes": {"a": {"who": "A Citizen", "text": "New in Crownfall? Spawn's the fountain, portals are up top, and everything you need to make is a door away. Mind the Choir.", "next": ""}}},
	"cap_guild": {"start": "a", "nodes": {"a": {"who": "Guild Steward", "text": "The Chartered Hall — charter a company, join one, sign on for guild work. The charters aren't drawn up yet, but the benches are warm. Soon.", "next": ""}}},
	"cap_petra": {"start": "a", "nodes": {"a": {"who": "Smith Petra", "text": "Crew Five ran the old royal foundry; now I run this fire. Everything with an edge comes through me — forge it new, or reforge what you've got: reroll a substat, re-cut an affix, right here at the anvil. Recipes pending; the reforge bench is already warm. Bring ore and patience.", "next": ""}}},
	"cap_sorrel": {"start": "a", "nodes": {"a": {"who": "Apprentice Sorrel", "text": "Herbalist Kesh lets me mind the Alembic when she's at the Menders' Row. Don't touch the green one. ...You touched the green one.", "next": ""}}},
	"cap_fenna": {"start": "a", "nodes": {"a": {"who": "Old Fenna", "text": "The Kitchen's mine. Grill sizzles, pan smokes, hearth never dies. Cook a thing worth eating and I'll teach you two more. Recipes pending, love.", "next": ""}}},
	"cap_tannery": {"start": "a", "nodes": {"a": {"who": "Tanner", "text": "Cured hides, honest stitching — this is where bags get made and made bigger. The trade's not open yet. Leave your measurements.", "next": ""}}},
	"cap_gardener": {"start": "a", "nodes": {"a": {"who": "Gardener", "text": "The Verdant Tiers feed the Kitchen and the Alembic both. Sow, wait, harvest. Nothing's growing on a schedule yet — but the beds are turned.", "next": ""}}},
	"cap_arena": {"start": "a", "nodes": {"a": {"who": "Proving Marshal", "text": "The Proving Gate. Sign your name and wait for the sand. No queue running today — the arena's a promise, not a pit. Yet.", "next": ""}}},
	"cap_lapidary": {"start": "a", "nodes": {"a": {"who": "The Lapidary", "text": "Gems and enchantment, not gearwork — take the anvil up the row for that. Here we cut and socket stones, synthesize the small ones into something worth setting, and bind the glow into a piece. Bring me raw stones and a steady hand.", "next": ""}}},
	"cap_echoes": {"start": "a", "nodes": {"a": {"who": "Hall Warden", "text": "Every deed you've done is filed here — bests, records, the fanfare wall. Skald Ottar sets the good ones to a verse, when he's not at his fire.", "next": ""}}},
	"cap_tankard": {"start": "a", "nodes": {"a": {"who": "Tavern Keeper", "text": "The Ashen Tankard — warmth, rumour, a fire that behaves. The whole city drifts through after dark. First cup's on the house for a shard-bearer.", "next": ""}}},
	"cap_gate": {"start": "a", "nodes": {"a": {"who": "Gate Sergeant", "text": "The Emberward Gate. Portcullis stays up in peacetime; the wild stays out on its honour. You came in clean — most do.", "next": ""}}},
	"cap_sighne": {"start": "a", "nodes": {"a": {"who": "Warden Sighne", "text": "Muster Square. I mark who comes and goes. You go a lot, by the look of that gear. Safe roads, shard-bearer.", "next": ""}}},
	"cap_palla": {"start": "a", "nodes": {"a": {"who": "Toll-Warden Palla", "text": "Stamps, seals, the gate ledger. No toll for the crowned and shard-touched — the city's glad enough you came back breathing.", "next": ""}}},
	"cap_callis": {"start": "a", "nodes": {"a": {"who": "Warden Callis", "text": "The tribes hold this enclave by truce, not welcome. Honest work, then: survey what the Waking's made of the east, and bring us word. Daily, if you're able.", "next": ""}}},
	"cap_ottar": {"start": "a", "nodes": {"a": {"who": "Skald Ottar", "text": "A fire that never dies and a skald who never stops. Go do a thing worth singing — I'll trade you the doing for the song. Come back with a story.", "next": ""}}},
	"cap_hunter": {"start": "a", "nodes": {"a": {"who": "The Old Hunter", "text": "This green's transplanted wildwood — the city lets us keep a scrap of the world we came from. Sit. Watch the treeline. It watches back.", "next": ""}}},
	"cap_haim": {"start": "a", "nodes": {"a": {"who": "Old Digger Haim", "text": "Sank this shaft under the enclave, into the old city's bones. I know what's down there. Guiding costs — knowing's free: don't go alone.", "next": ""}}},
	"cap_ilse": {"start": "a", "nodes": {"a": {"who": "Cantor Ilse", "text": "The Choir does not bury its dead — rot is the land's honest truth, and the dead keep their own vigil here. Tend them with me. It's patient work. Daily work.", "next": ""}}},
	"cap_vela": {"start": "a", "nodes": {"a": {"who": "Deacon Vela", "text": "Quieter tasks than the Cantor's: recover a relic, carry a name north to the sleepers, witness a thing and return unbroken. The blight rewards the faithful.", "next": ""}}},
	"cap_osk": {"start": "a", "nodes": {"a": {"who": "Brother Osk", "text": "I tend the ones lying down to wait for the Waking. I was something else, before. Ask me nothing; the sleepers dislike questions.", "next": ""}}},
	"cap_suli": {"start": "a", "nodes": {"a": {"who": "Gentle Suli", "text": "Even a cold faith gets sick. I mend the Choir's living — the one warm corner of the enclave. You look whole. Stay that way out there.", "next": ""}}},
	"cap_sera": {"start": "a", "nodes": {"a": {"who": "Widow Sera", "text": "I keep the Sexton's Gate down into the undercroft, among the dead. I decide who goes. I mostly say no. ...You've the look of a yes.", "next": ""}}},
	"cap_maren": {"start": "a", "nodes": {"a": {"who": "Elder Maren", "text": "So — the shards still choosing, and the factions still counting. The Accord holds this ward and half this city's conscience. There's honest work daily, if you want it. Sit; the fire doesn't bite.", "next": ""}}},
	"cap_kesh": {"start": "a", "nodes": {"a": {"who": "Herbalist Kesh", "text": "The Menders' Row — cures for the ward, reagents for the Alembic. I set the day's gathering. Bring back the right leaves and no one dies of the wrong ones.", "next": ""}}},
	"cap_osla": {"start": "a", "nodes": {"a": {"who": "Tinker Osla", "text": "Osla's yard — half-mended things and honest barter. There — seated. You've a strong shoulder for someone armed to the teeth. Flame keep you.", "next": ""}}},
	"cap_dov": {"start": "a", "nodes": {"a": {"who": "Fisher Dov", "text": "Still fish the cistern-water, if you can believe it. Ansa watches a tide that isn't there and swears it'll come back. Maybe it will. Odd city, this.", "next": ""}}},
	"cap_aldric": {"start": "a", "nodes": {"a": {"who": "Ser Aldric", "text": "The Cinderborn keep the forms of a court that lost its crown. I keep its sword arm. There's work in the old key — recover, restore, avenge — for a crown that might yet find a head. Daily, if you've the stomach.", "next": ""}}},
	"cap_vessa": {"start": "a", "nodes": {"a": {"who": "Envoy Vessa", "text": "Work with us and be paid, protected, and remembered. I've a commission most days — a courier run, a quiet errand, imperial paper with teeth. First one's waiting.", "next": ""}}},
	"cap_brann": {"start": "a", "nodes": {"a": {"who": "Overseer Brann", "text": "Here's the honest ledger: the Compact reopened these foundries, best ore two years running. The Forge upstairs eats what we dig. Good trade, if you can haul.", "next": ""}}},
	"cap_vasse": {"start": "a", "nodes": {"a": {"who": "Retired Keeper Vasse", "text": "Pre-Vargoth history, all of it — the Cinderborn's whole claim, written in old ink. A crown is a thing that can be re-forged, if you read the right page. I guard the page.", "next": ""}}},
	"cap_ashe": {"start": "a", "nodes": {"a": {"who": "Warden-Commander Ashe", "text": "The Muster Yard. I drill those who'll hold a line for the idea of a king — old-regime steel, still marching. Fall in or pass through; either's fine, shard-bearer.", "next": ""}}},
}


## Merge + integrity selftest: the world resolves, every zone is safe with a
## valid terrain, every NPC convo/action is wired, the graph is connected.
static func selftest(_game: Node2D) -> String:
	var ch: Dictionary = Story.chapter("capital")
	if ch.get("zones", []).size() != 50:
		return "capital: expected 50 zones, got %d" % ch.get("zones", []).size()
	var coords := {}
	for z in ch["zones"]:
		if z.get("type", "") != "safe":
			return "capital: zone %s is not safe" % z.get("name", "?")
		if not Terrains.DATA.has(String(z.get("terrain", ""))):
			return "capital: zone %s has unknown terrain %s" % [z.get("name","?"), z.get("terrain","")]
		var c: Array = z.get("coord", [])
		var key := "%d,%d" % [int(c[0]), int(c[1])]
		if coords.has(key):
			return "capital: duplicate coord %s" % key
		coords[key] = true
		for npc in z.get("npcs", []):
			if npc.has("convo") and not Story.ALL_CONVOS.has(String(npc["convo"])):
				return "capital: NPC convo %s not registered" % npc["convo"]
			if Art.tex(String(npc["sprite"])) == null:
				return "capital: NPC sprite %s missing" % npc["sprite"]
	return ""
